FROM debian:stable-slim

# Prevent interactive prompts during installation
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies, build tools, MPI, and Qt6 development libraries
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    meson \
    ninja-build \
    cmake \
    clang \
    lldb \
    libopenmpi-dev \
    openmpi-bin \
    qt6-base-dev \
    qt6-declarative-dev \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Create a non-root user matching the original setup
RUN useradd -m -s /bin/bash gridlockuser

WORKDIR /workspace
COPY . /workspace
RUN chown -R gridlockuser:gridlockuser /workspace

USER gridlockuser

# Configure the build system
RUN rm -rf build && meson setup build